const { createClient } = require('@supabase/supabase-js');

// O Netlify lerá as variáveis de ambiente configuradas no painel de controle
const SUPABASE_URL = process.env.SUPABASE_URL;
const SUPABASE_KEY = process.env.SUPABASE_KEY; // Use a chave anon aqui
const supabase = createClient(SUPABASE_URL, SUPABASE_KEY);

// Dicionário para embutir emojis de bandeiras baseados no código FIFA
const emojisBandeiras = {
    "BRA": "🇧🇷", "GER": "🇩🇪", "ESP": "🇪🇸", "FRA": "🇫🇷", "ENG": "🏴󠁧󠁢󠁥󠁮󠁧󠁿", 
    "ARG": "🇦🇷", "POR": "🇵🇹", "NED": "🇳🇱", "BEL": "🇧🇪", "ITA": "🇮🇹",
    "URU": "🇺🇾", "COL": "🇨🇴", "MEX": "🇲🇽", "USA": "🇺🇸", "CAN": "🇨🇦"
    // Adicione mais conforme os códigos cadastrados no seu banco
};

exports.handler = async (event, context) => {
    try {
        // 1. Puxa seleções e jogos em paralelo para máxima performance
        const [resSelecoes, resJogos] = await Promise.all([
            supabase.from('selecoes').select('*'),
            supabase.from('jogos').select('*').order('data_hora', { ascending: true })
        ]);

        const selecoes = resSelecoes.data || [];
        const jogos = resJogos.data || [];

        const getEquipa = (id, desc) => {
            return selecoes.find(s => s.id === id) || { nome_ptbr: desc || 'A Definir', codigo_fifa: '' };
        };

        // 2. Monta o cabeçalho do arquivo iCalendar
        let icsConteudo = [
            "BEGIN:VCALENDAR",
            "VERSION:2.0",
            "PRODID:-//Copa2026//Calendario Dinamico//PT",
            "X-WR-CALNAME:Copa do Mundo 2026",
            "X-WR-TIMEZONE:UTC",
            "REFRESH-INTERVAL;VALUE=DURATION:PT15M", // Pede para a agenda atualizar a cada 15 min
            "X-PUBLISHED-TTL:PT15M"
        ].join("\r\n") + "\r\n";

        // 3. Processa cada jogo do banco de dados
        jogos.forEach(jogo => {
            const casa = getEquipa(jogo.time_casa_id, jogo.desc_casa);
            const fora = getEquipa(jogo.time_visitante_id, jogo.desc_visitante);

            const flagCasa = emojisBandeiras[casa.codigo_fifa] || "";
            const flagFora = emojisBandeiras[fora.codigo_fifa] || "";

            // Monta o título dinâmico com base no status do jogo
            let titulo = "";
            if (jogo.status === "Encerrado" || jogo.status === "Em Andamento") {
                titulo = `${flagCasa} ${casa.nome_ptbr} ${jogo.gols_casa} x ${jogo.gols_visitante} ${fora.nome_ptbr} ${flagFora} (${jogo.status})`;
            } else {
                titulo = `${flagCasa} ${casa.nome_ptbr} x ${fora.nome_ptbr} ${flagFora}`;
            }

            // Formatação de datas no padrão ICS (YYYYMMDDTHHMMSSZ)
            const dataInicio = new Date(jogo.data_hora);
            const dataFim = new Date(dataInicio.getTime() + 2 * 60 * 60 * 1000); // Adiciona 2 horas para a duração do jogo

            const formatarDataICS = (date) => date.toISOString().replace(/[-:]/g, "").split(".")[0] + "Z";

            icsConteudo += [
                "BEGIN:VEVENT",
                `UID:jogo_2026_${jogo.id}`,
                `DTSTART:${formatarDataICS(dataInicio)}`,
                `DTEND:${formatarDataICS(dataFim)}`,
                `SUMMARY:${titulo}`,
                `DESCRIPTION:Fase: ${jogo.fase}\\nStatus: ${jogo.status}`,
                "LOCATION:Estádio da Partida",
                "END:VEVENT"
            ].join("\r\n") + "\r\n";
        });

        icsConteudo += "END:VCALENDAR";

        // 4. Retorna o arquivo com os cabeçalhos corretos para assinatura de calendário
        return {
            statusCode: 200,
            headers: {
                "Content-Type": "text/calendar; charset=utf-8",
                "Content-Disposition": "inline; filename=calendario_copa.ics"
            },
            body: icsConteudo
        };

    } catch (error) {
        return { statusCode: 500, body: JSON.stringify({ error: error.message 
}) };
    }
};
